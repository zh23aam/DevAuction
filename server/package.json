{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step defined for server.'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "async-mutex": "^0.4.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^137.1.0",
    "http": "^0.0.1-security",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "livekit-server-sdk": "^2.15.0",
    "moment": "^2.30.1",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-pre-gyp": "^0.17.0",
    "nodemailer": "^6.9.13",
    "nodemon": "^3.1.2",
    "razorpay": "^2.9.4",
    "socket.io": "^4.7.5",
    "tslib": "^2.8.1",
    "winston": "^3.19.0",
    "wrtc": "^0.4.7"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "supertest": "^6.3.4"
  }
}
