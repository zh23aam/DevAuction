# Backend Environment Variables
# Copy this file to .env and fill in the actual values

# Server Configuration
PORT=3000

# Database Configuration
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/
DB_NAME=database_name

# Email Configuration
EMAIL=your-email@gmail.com
APP_PASSWD=your-app-password

# Payment Gateway (Razorpay)
RAZORPAY_ID_KEY=your_razorpay_key_id
RAZORPAY_SECRET_KEY=your_razorpay_secret_key
Webhook_Secret=your_webhook_secret

# Google Drive Integration
GOOGLE_DRIVE_FOLDER_ID=your_folder_id
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Video Conferencing (Zego - Legacy)
ZEGO_APP_ID=your_zego_app_id
ZEGO_SERVER_SECRET=your_zego_server_secret

# LiveKit Configuration (Backend Only - NEVER expose to frontend)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=https://your-livekit-instance.livekit.cloud

# Auth0 Configuration (Backend Only - RS256 JWT verification)
# Get these values from your Auth0 application settings
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=your-api-identifier

# Auction Configuration
HOST_DISCONNECT_GRACE_PERIOD_MS=300000
